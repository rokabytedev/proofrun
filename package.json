{
  "name": "proofrun",
  "version": "0.3.1",
  "description": "Teach your coding agent to prove its own work — evidence, not claims",
  "type": "module",
  "bin": {
    "proofrun": "bin/proofrun.js"
  },
  "files": [
    "bin/",
    "src/",
    "!**/*.test.js",
    "skills/",
    "templates/"
  ],
  "scripts": {
    "test": "node --test --test-name-pattern='.*' src/*.test.js src/commands/*.test.js"
  },
  "keywords": [
    "ai-agent",
    "agent-skill",
    "verification",
    "mobile",
    "evidence",
    "report",
    "proof-of-work",
    "claude-code"
  ],
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rokabytedev/proofrun"
  },
  "author": "rokabytedev",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "proper-lockfile": "^4.1.2",
    "toml": "^3.0.0"
  }
}
