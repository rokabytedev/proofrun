{
  "name": "proofrun",
  "version": "0.1.0",
  "description": "CLI tool for AI agent verification workflows — capture evidence, generate interactive reports",
  "type": "module",
  "bin": {
    "proofrun": "./bin/proofrun.js"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "presets/",
    "templates/"
  ],
  "scripts": {
    "test": "node --test --test-name-pattern='.*' src/*.test.js src/commands/*.test.js"
  },
  "keywords": [
    "ai",
    "agent",
    "verification",
    "testing",
    "simulator",
    "evidence",
    "report"
  ],
  "author": "rokabytedev",
  "license": "MIT",
  "dependencies": {
    "commander": "^13.1.0",
    "js-yaml": "^4.1.0",
    "proper-lockfile": "^4.1.2"
  }
}
